{
  "$schema": "https://turbo.build/schema.json",
  "remoteCache": {
    "signature": false
  },
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "env": [
        "NODE_ENV",
        "DATABASE_URL",
        "DIRECT_DATABASE_URL",
        "API_URI",
        "DASHBOARD_URI",
        "LANDING_URI",
        "WIKI_URI",
        "NEXT_PUBLIC_API_URI",
        "NEXT_PUBLIC_LANDING_URI",
        "NEXT_PUBLIC_DASHBOARD_URI",
        "NEXT_PUBLIC_WIKI_URI",
        "OIDC_ISSUER",
        "OIDC_CLIENT_ID",
        "OIDC_CLIENT_SECRET",
        "OIDC_SCOPES",
        "OIDC_DISPLAY_NAME",
        "OIDC_EMAIL_CLAIM",
        "OIDC_EMAIL_VERIFIED_CLAIM",
        "OIDC_REQUIRE_EMAIL_VERIFIED",
        "OIDC_ALLOW_SIGNUPS",
        "OIDC_LINK_EXISTING_BY_VERIFIED_EMAIL"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**"
      ]
    },
    "sitemap": {
      "dependsOn": [
        "build"
      ],
      "outputs": [
        "public/robots.txt",
        "public/sitemap*.xml"
      ]
    },
    "deploy": {
      "dependsOn": [
        "build",
        "sitemap"
      ],
      "outputs": []
    },
    "start": {
      "dependsOn": [
        "^start"
      ],
      "env": [
        "NODE_ENV",
        "PORT",
        "JWT_SECRET",
        "DATABASE_URL",
        "DIRECT_DATABASE_URL",
        "REDIS_URL",
        "API_URI",
        "DASHBOARD_URI",
        "LANDING_URI",
        "WIKI_URI",
        "S3_ENDPOINT",
        "S3_ACCESS_KEY_ID",
        "S3_ACCESS_KEY_SECRET",
        "S3_BUCKET",
        "S3_PUBLIC_URL",
        "S3_FORCE_PATH_STYLE",
        "AWS_SES_REGION",
        "AWS_SES_ACCESS_KEY_ID",
        "AWS_SES_SECRET_ACCESS_KEY",
        "SES_CONFIGURATION_SET",
        "SES_CONFIGURATION_SET_NO_TRACKING",
        "EMAIL_RATE_LIMIT_PER_SECOND",
        "GITHUB_OAUTH_CLIENT",
        "GITHUB_OAUTH_SECRET",
        "GOOGLE_OAUTH_CLIENT",
        "GOOGLE_OAUTH_SECRET",
        "STRIPE_SK",
        "STRIPE_WEBHOOK_SECRET",
        "STRIPE_PRICE_ONBOARDING",
        "STRIPE_PRICE_EMAIL_USAGE",
        "STRIPE_METER_EVENT_NAME",
        "NEXT_PUBLIC_API_URI",
        "NEXT_PUBLIC_LANDING_URI",
        "NEXT_PUBLIC_DASHBOARD_URI",
        "NEXT_PUBLIC_WIKI_URI",
        "PLUNK_API_KEY",
        "PLUNK_FROM_ADDRESS",
        "NTFY_URL",
        "SMTP_ENABLED",
        "SMTP_DOMAIN",
        "PORT_SECURE",
        "PORT_SUBMISSION",
        "AUTO_PROJECT_DISABLE",
        "DISABLE_SIGNUPS",
        "VERIFY_EMAIL_ON_SIGNUP",
        "OPENROUTER_API_KEY",
        "OPENROUTER_MODEL",
        "PHISHING_DETECTION_SAMPLE_RATE",
        "PHISHING_CONFIDENCE_THRESHOLD",
        "PHISHING_CUMULATIVE_THRESHOLD",
        "PHISHING_CUMULATIVE_WINDOW_MS",
        "OIDC_ISSUER",
        "OIDC_CLIENT_ID",
        "OIDC_CLIENT_SECRET",
        "OIDC_SCOPES",
        "OIDC_DISPLAY_NAME",
        "OIDC_EMAIL_CLAIM",
        "OIDC_EMAIL_VERIFIED_CLAIM",
        "OIDC_REQUIRE_EMAIL_VERIFIED",
        "OIDC_ALLOW_SIGNUPS",
        "OIDC_LINK_EXISTING_BY_VERIFIED_EMAIL"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ],
      "cache": false,
      "persistent": true
    },
    "check-types": {
      "dependsOn": [
        "^check-types"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "NODE_ENV",
        "PORT",
        "JWT_SECRET",
        "DATABASE_URL",
        "DIRECT_DATABASE_URL",
        "REDIS_URL",
        "API_URI",
        "DASHBOARD_URI",
        "LANDING_URI",
        "WIKI_URI",
        "S3_ENDPOINT",
        "S3_ACCESS_KEY_ID",
        "S3_ACCESS_KEY_SECRET",
        "S3_BUCKET",
        "S3_PUBLIC_URL",
        "S3_FORCE_PATH_STYLE",
        "AWS_SES_REGION",
        "AWS_SES_ACCESS_KEY_ID",
        "AWS_SES_SECRET_ACCESS_KEY",
        "SES_CONFIGURATION_SET",
        "SES_CONFIGURATION_SET_NO_TRACKING",
        "EMAIL_RATE_LIMIT_PER_SECOND",
        "GITHUB_OAUTH_CLIENT",
        "GITHUB_OAUTH_SECRET",
        "GOOGLE_OAUTH_CLIENT",
        "GOOGLE_OAUTH_SECRET",
        "STRIPE_SK",
        "STRIPE_WEBHOOK_SECRET",
        "STRIPE_PRICE_ONBOARDING",
        "STRIPE_PRICE_EMAIL_USAGE",
        "STRIPE_METER_EVENT_NAME",
        "NEXT_PUBLIC_API_URI",
        "NEXT_PUBLIC_LANDING_URI",
        "NEXT_PUBLIC_DASHBOARD_URI",
        "NEXT_PUBLIC_WIKI_URI",
        "PLUNK_API_KEY",
        "PLUNK_FROM_ADDRESS",
        "NTFY_URL",
        "SMTP_ENABLED",
        "SMTP_DOMAIN",
        "PORT_SECURE",
        "PORT_SUBMISSION",
        "AUTO_PROJECT_DISABLE",
        "DISABLE_SIGNUPS",
        "VERIFY_EMAIL_ON_SIGNUP",
        "OPENROUTER_API_KEY",
        "OPENROUTER_MODEL",
        "PHISHING_DETECTION_SAMPLE_RATE",
        "PHISHING_CONFIDENCE_THRESHOLD",
        "PHISHING_CUMULATIVE_THRESHOLD",
        "PHISHING_CUMULATIVE_WINDOW_MS",
        "OIDC_ISSUER",
        "OIDC_CLIENT_ID",
        "OIDC_CLIENT_SECRET",
        "OIDC_SCOPES",
        "OIDC_DISPLAY_NAME",
        "OIDC_EMAIL_CLAIM",
        "OIDC_EMAIL_VERIFIED_CLAIM",
        "OIDC_REQUIRE_EMAIL_VERIFIED",
        "OIDC_ALLOW_SIGNUPS",
        "OIDC_LINK_EXISTING_BY_VERIFIED_EMAIL"
      ]
    },
    "dev:worker": {
      "cache": false,
      "persistent": true,
      "env": [
        "NODE_ENV",
        "PORT",
        "JWT_SECRET",
        "DATABASE_URL",
        "DIRECT_DATABASE_URL",
        "REDIS_URL",
        "API_URI",
        "DASHBOARD_URI",
        "LANDING_URI",
        "WIKI_URI",
        "S3_ENDPOINT",
        "S3_ACCESS_KEY_ID",
        "S3_ACCESS_KEY_SECRET",
        "S3_BUCKET",
        "S3_PUBLIC_URL",
        "S3_FORCE_PATH_STYLE",
        "AWS_SES_REGION",
        "AWS_SES_ACCESS_KEY_ID",
        "AWS_SES_SECRET_ACCESS_KEY",
        "SES_CONFIGURATION_SET",
        "SES_CONFIGURATION_SET_NO_TRACKING",
        "EMAIL_RATE_LIMIT_PER_SECOND",
        "GITHUB_OAUTH_CLIENT",
        "GITHUB_OAUTH_SECRET",
        "GOOGLE_OAUTH_CLIENT",
        "GOOGLE_OAUTH_SECRET",
        "STRIPE_SK",
        "STRIPE_WEBHOOK_SECRET",
        "STRIPE_PRICE_ONBOARDING",
        "STRIPE_PRICE_EMAIL_USAGE",
        "STRIPE_METER_EVENT_NAME",
        "NEXT_PUBLIC_API_URI",
        "NEXT_PUBLIC_LANDING_URI",
        "NEXT_PUBLIC_DASHBOARD_URI",
        "NEXT_PUBLIC_WIKI_URI",
        "PLUNK_API_KEY",
        "PLUNK_FROM_ADDRESS",
        "NTFY_URL",
        "SMTP_ENABLED",
        "SMTP_DOMAIN",
        "PORT_SECURE",
        "PORT_SUBMISSION",
        "AUTO_PROJECT_DISABLE",
        "DISABLE_SIGNUPS",
        "VERIFY_EMAIL_ON_SIGNUP",
        "OPENROUTER_API_KEY",
        "OPENROUTER_MODEL",
        "PHISHING_DETECTION_SAMPLE_RATE",
        "PHISHING_CONFIDENCE_THRESHOLD",
        "PHISHING_CUMULATIVE_THRESHOLD",
        "PHISHING_CUMULATIVE_WINDOW_MS",
        "OIDC_ISSUER",
        "OIDC_CLIENT_ID",
        "OIDC_CLIENT_SECRET",
        "OIDC_SCOPES",
        "OIDC_DISPLAY_NAME",
        "OIDC_EMAIL_CLAIM",
        "OIDC_EMAIL_VERIFIED_CLAIM",
        "OIDC_REQUIRE_EMAIL_VERIFIED",
        "OIDC_ALLOW_SIGNUPS",
        "OIDC_LINK_EXISTING_BY_VERIFIED_EMAIL"
      ]
    },
    "clean": {
      "cache": false,
      "persistent": true
    }
  }
}
